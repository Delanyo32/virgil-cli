# Issue #13 — Rust pilot snapshot. Counts the rows the type +
# signature + inheritance extractor produces against
# benchmarks/rust/systems-cli. Update `types-and-hierarchy.expected`
# in lock-step when the extractor or benchmark intentionally changes.
#
# Each query in this file is also encoded in
# tests/snapshot_types_and_hierarchy.rs; this file exists for human
# reproduction via `cargo run -- projects query`.

# Total `type` rows (unique per (file, display_name)).
?[count(t)] := *type{id: t}

# By kind.
?[count(t)] := *type{id: t, kind: "primitive"}
?[count(t)] := *type{id: t, kind: "named"}
?[count(t)] := *type{id: t, kind: "generic"}
?[count(t)] := *type{id: t, kind: "tuple"}
?[count(t)] := *type{id: t, kind: "array"}
?[count(t)] := *type{id: t, kind: "function"}
?[count(t)] := *type{id: t, kind: "intersection"}

# Resolved canonical names.
?[count(t)] := *type{id: t, canonical_name: c}, c != null

# Parameter coverage.
?[count(p)] := *parameter{id: p}
?[count(p)] := *parameter{id: p, type_id: tid}, tid != null

# Returns coverage.
?[count(f)] := *returns_type{function_id: f}

# Inheritance.
?[count(c)] := *extends{child_id: c}
?[count(i)] := *implements{impl_id: i}
