# find_function_by_name — locate symbols by exact name.
# Params:
#   $name — symbol name to match exactly.
# Example:
#   --template find_function_by_name --param name=login

?[name, kind, file_path, start_line, end_line] :=
    *symbol{name, kind, file_path, start_line, end_line},
    name = $name
:order file_path, start_line
