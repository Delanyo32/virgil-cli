# import_depth — compute the longest path of file imports leading into each
# file. A file with depth 0 is imported by nobody.
#
# Returns rows of (file, depth). Floats produced by min/max; cast in your
# templates if you need integers.

depth[f, d] :=
    *file{path: f}, d = 0,
    not *imports{imported_id: f}

depth[f, d] :=
    *imports{importer_file_id: a, imported_id: f},
    depth[a, d_a],
    d = d_a + 1

?[file, depth] := depth[file, depth]
:order -depth, file
