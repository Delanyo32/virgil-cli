{
  "pipeline": "api_surface_area_python",
  "category": "architecture",
  "description": "Detect Python files that export an excessive fraction of their symbols",
  "languages": ["python"],
  "graph": [
    {
      "select": "symbol",
      "exclude": {
        "or": [
          {"is_test_file": true},
          {"is_generated": true}
        ]
      }
    },
    {"group_by": "file"},
    {
      "ratio": {
        "numerator": {"where": {"exported": true}},
        "denominator": {},
        "threshold": {
          "and": [
            {"count": {"gte": 10}},
            {"ratio": {"gte": 0.8}}
          ]
        }
      }
    },
    {
      "flag": {
        "pattern": "excessive_public_api",
        "message": "Excessive public API: {{file}} exports {{count}} symbols ({{ratio}}% of total)",
        "severity": "info"
      }
    }
  ]
}
