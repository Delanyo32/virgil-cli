{
  "pipeline": "ssrf_javascript",
  "category": "security",
  "description": "Detect SSRF in JavaScript: user input reaching outbound network calls",
  "languages": [
    "javascript"
  ],
  "graph": [
    {
      "taint_sources": [
        {
          "pattern": "req.body",
          "kind": "user_input"
        },
        {
          "pattern": "req.query",
          "kind": "user_input"
        },
        {
          "pattern": "req.params",
          "kind": "user_input"
        },
        {
          "pattern": "req.headers",
          "kind": "user_input"
        },
        {
          "pattern": "process.env",
          "kind": "env_var"
        }
      ]
    },
    {
      "taint_sanitizers": [
        {
          "pattern": "new URL("
        },
        {
          "pattern": "urlparse"
        },
        {
          "pattern": "allowlist"
        },
        {
          "pattern": "isAllowed"
        },
        {
          "pattern": "validateUrl"
        }
      ]
    },
    {
      "taint_sinks": [
        {
          "pattern": "fetch(",
          "vulnerability": "ssrf"
        },
        {
          "pattern": "axios.get",
          "vulnerability": "ssrf"
        },
        {
          "pattern": "axios.post",
          "vulnerability": "ssrf"
        },
        {
          "pattern": "http.get(",
          "vulnerability": "ssrf"
        },
        {
          "pattern": "http.request(",
          "vulnerability": "ssrf"
        },
        {
          "pattern": "got(",
          "vulnerability": "ssrf"
        },
        {
          "pattern": "request(",
          "vulnerability": "ssrf"
        },
        {
          "pattern": "res.redirect",
          "vulnerability": "ssrf"
        }
      ]
    },
    {
      "flag": {
        "pattern": "ssrf",
        "message": "SSRF: tainted value from '{{tainted_var}}' reaches {{sink}} in {{file}}:{{line}}",
        "severity": "error"
      }
    }
  ]
}
