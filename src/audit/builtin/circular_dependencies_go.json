{
  "pipeline": "circular_dependencies_go",
  "category": "architecture",
  "description": "Detect circular import chains in Go using Tarjan SCC algorithm",
  "languages": ["go"],
  "graph": [
    {
      "select": "file",
      "exclude": {
        "or": [
          {"is_test_file": true},
          {"is_generated": true}
        ]
      }
    },
    {"find_cycles": {"edge": "imports"}},
    {
      "flag": {
        "pattern": "circular_dependency",
        "message": "Circular dependency ({{cycle_size}} files): {{cycle_path}}",
        "severity_map": [
          {"when": {"cycle_size": {"eq": 2}}, "severity": "info"},
          {"when": {"cycle_size": {"lte": 5}}, "severity": "warning"},
          {"severity": "error"}
        ]
      }
    }
  ]
}
