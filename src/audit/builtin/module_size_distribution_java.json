{
  "pipeline": "module_size_distribution_java",
  "category": "architecture",
  "description": "Detect Java files that have grown too large (too many symbol definitions)",
  "languages": [
    "java"
  ],
  "graph": [
    {
      "select": "symbol",
      "exclude": {
        "or": [
          {
            "is_test_file": true
          },
          {
            "is_generated": true
          },
          {
            "is_barrel_file": true
          }
        ]
      }
    },
    {
      "group_by": "file"
    },
    {
      "count": {
        "threshold": {
          "gte": 30
        }
      }
    },
    {
      "flag": {
        "pattern": "oversized_module",
        "message": "Oversized module: {{file}} has {{count}} definitions",
        "severity_map": [
          {
            "when": {
              "metrics": {
                "count": {
                  "gte": 100
                }
              }
            },
            "severity": "error"
          },
          {
            "when": {
              "metrics": {
                "count": {
                  "gte": 50
                }
              }
            },
            "severity": "warning"
          },
          {
            "severity": "info"
          }
        ]
      }
    }
  ]
}
