{
  "pipeline": "coupling",
  "category": "code-quality",
  "description": "Detects Java files with high import count (high fan-out coupling). Warning >= 8 import declarations, error >= 15.",
  "languages": [
    "java"
  ],
  "graph": [
    {
      "match_pattern": "(import_declaration) @import"
    },
    {
      "group_by": "file"
    },
    {
      "count": {
        "threshold": {
          "gte": 8
        }
      }
    },
    {
      "flag": {
        "pattern": "high_coupling",
        "message": "{{file}} has {{count}} import declarations — high fan-out coupling",
        "severity_map": [
          {
            "when": { "metrics": { "count": { "gte": 15 } } },
            "severity": "error"
          },
          {
            "when": { "metrics": { "count": { "gte": 8 } } },
            "severity": "warning"
          }
        ]
      }
    }
  ]
}
