{
  "pipeline": "api_surface_area_java",
  "category": "architecture",
  "description": "Detect Java files that export an excessive fraction of their symbols",
  "languages": [
    "java"
  ],
  "graph": [
    {
      "select": "symbol",
      "exclude": {
        "or": [
          {
            "is_test_file": true
          },
          {
            "is_generated": true
          }
        ]
      }
    },
    {
      "group_by": "file"
    },
    {
      "ratio": {
        "numerator": {
          "where": {
            "exported": true
          }
        },
        "denominator": {},
        "threshold": {
          "and": [
            {
              "metrics": {
                "count": {
                  "gte": 20
                }
              }
            },
            {
              "metrics": {
                "ratio": {
                  "gte": 0.8
                }
              }
            }
          ]
        }
      }
    },
    {
      "flag": {
        "pattern": "excessive_public_api",
        "message": "Excessive public API: {{file}} exports {{count}} symbols ({{ratio}}% of total)",
        "severity": "info"
      }
    }
  ]
}
