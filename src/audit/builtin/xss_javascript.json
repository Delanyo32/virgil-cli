          "vulnerability": "xss"
        },
        {
          "pattern": "insertAdjacentHTML",
          "vulnerability": "xss"
        },
        {
          "pattern": "eval(",
          "vulnerability": "xss"
        },
        {
          "pattern": "Function(",
          "vulnerability": "xss"
        },
        {
          "pattern": "setTimeout(",
          "vulnerability": "xss"
        },
        {
          "pattern": "setInterval(",
          "vulnerability": "xss"
