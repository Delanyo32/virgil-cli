          "kind": "user_input"
        },
        {
          "pattern": "location.search",
          "kind": "user_input"
        },
        {
          "pattern": "location.href",
          "kind": "user_input"
        },
        {
          "pattern": "document.cookie",
          "kind": "user_input"
        },
        {
          "pattern": "window.location",
          "kind": "user_input"
        },
        {
          "pattern": "URLSearchParams",
          "kind": "user_input"
        }
      ]
    },
    {
      "taint_sanitizers": [
        {
          "pattern": "DOMPurify.sanitize"
        },
        {
